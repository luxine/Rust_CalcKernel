{
  "name": "calckernel",
  "version": "0.8.0",
  "description": "Rust rewrite of the CK / CalcKernel compiler with C, WASM, and LLVM backends.",
  "type": "module",
  "main": "./npm/index.js",
  "types": "./npm/index.d.ts",
  "exports": {
    ".": {
      "types": "./npm/index.d.ts",
      "import": "./npm/index.js"
    }
  },
  "bin": {
    "ckc": "./npm/ckc.js"
  },
  "files": [
    "npm",
    "README.md",
    "docs/npm-release.md",
    "docs/architecture-review.md",
    "docs/zh-CN/architecture-review.md"
  ],
  "scripts": {
    "audit:release-workflow": "node scripts/audit-npm-release-workflow.mjs",
    "audit:typescript-test-surface": "node scripts/audit-typescript-test-surface.mjs",
    "build": "cargo build --release",
    "build:npm-matrix": "node scripts/build-npm-binary-matrix.mjs",
    "ckc": "node npm/ckc.js",
    "prepack": "cargo build --release --quiet && node scripts/prepare-npm-package.mjs",
    "postpack": "node scripts/cleanup-npm-package.mjs",
    "test": "cargo test",
    "verify:cutover-evidence": "node scripts/verify-npm-cutover-evidence.mjs",
    "verify:declaration-parity": "node scripts/verify-declaration-parity.mjs",
    "verify:host-npm-install": "node scripts/verify-host-npm-install.mjs",
    "verify:npm-release": "node scripts/verify-npm-release.mjs",
    "verify:public-api-parity": "node scripts/verify-public-api-parity.mjs",
    "verify:publish-artifact": "node scripts/verify-npm-publish-artifact.mjs",
    "verify:publish-result": "node scripts/verify-npm-publish-result.mjs",
    "verify:registry-replacement": "node scripts/verify-npm-registry-replacement.mjs",
    "verify:release-signoff": "node scripts/verify-npm-release-signoff.mjs",
    "verify:typescript-oracle": "node scripts/verify-typescript-oracle.mjs"
  },
  "keywords": [
    "calckernel",
    "ck",
    "compiler",
    "dsl",
    "c",
    "wasm",
    "llvm",
    "rust"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  }
}
