export fn add_i64(a: i64, b: i64) -> i64 {
  return a + b;
}

export fn mul_i64(a: i64, b: i64) -> i64 {
  return a * b;
}

export fn div_i64(a: i64, b: i64) -> i64 {
  return a / b;
}

export fn neg_i64(a: i64) -> i64 {
  return -a;
}

export fn less_i64(a: i64, b: i64) -> bool {
  return a < b;
}
